@model EcommerceCheckout.Web.Models.ViewModels.CartSummary

<h1>Carello:</h1>
<p>Token: @Model.Cart.CartToken</p>

<div id="cart-alert" style="color: red;"></div>

@if (!Model.Cart.Items.Any())
{
    <p>Il carello é vuoto.</p>
}
else
{
    <ul>
        @foreach (var item in Model.Cart.Items)
        {
            <li data-product-id="@item.ProductId">
                @item.Product.Name - 
                Quantità: <span class="qty-value">@item.Quantity</span> - 
                Prezzo: <span class="qty-price">@item.UnitPrice</span>
                <button class="qty-minus" data-product-id="@item.ProductId">-</button>
                <button class="qty-plus" data-product-id="@item.ProductId">+</button>
                <button class="qty-remove" data-product-id="@item.ProductId">Rimuovi</button>
            </li>
        }
    </ul>
    
    <div>
        <input type="text" id="coupon-code" placeholder="Inserisci codice coupon" />
        <button id="apply-coupon-btn">Applica Coupon</button>
    </div>
    
    <div>
        <p>Subtotale: <span id="cart-subtotal">@Model.Subtotal.ToString("C")</span></p>
        <p>Sconto: <span id="cart-discount">@Model.Discount.ToString("C")</span></p>
        <p>Totale: <span id="cart-total">@Model.Total.ToString("C")</span></p>
        <a href="/user-info" id="checkout-btn">Procedi al Checkout</a>
    </div>
}

@section Scripts
{
    <script src="~/js/cart.js"></script>
}
